{
  "name": "watch-pixiv-bookmarks",
  "version": "3.0.0",
  "description": "Monitor pixiv bookmarks and notify Discord when new items are added.",
  "homepage": "https://github.com/tomacheese/watch-pixiv-bookmarks",
  "bugs": {
    "url": "https://github.com/tomacheese/watch-pixiv-bookmarks/issues"
  },
  "license": "MIT",
  "author": "Tomachi <tomachi@tomacheese.com>",
  "private": true,
  "main": "dist/main.js",
  "repository": {
    "url": "git@github.com:tomacheese/watch-pixiv-bookmarks.git",
    "type": "git"
  },
  "scripts": {
    "dev": "tsx watch ./src/main.ts",
    "fix": "run-z fix:prettier fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:prettier": "prettier --check src",
    "lint:tsc": "tsc",
    "preinstall": "npx only-allow pnpm",
    "start": "tsx ./src/main.ts",
    "test": "jest --runInBand --passWithNoTests --detectOpenHandles --forceExit"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.16.13",
    "@book000/node-utils": "1.24.294",
    "@book000/pixivts": "0.62.0",
    "@types/jest": "30.0.0",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "jest-expect-message": "1.1.3",
    "prettier": "3.9.5",
    "run-z": "2.1.0",
    "ts-jest": "29.4.11",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "setupFilesAfterEnv": [
      "jest-expect-message"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/*.test.ts"
    ]
  },
  "packageManager": "pnpm@11.15.0+sha512.266f8957a30d2be6e9468e5e66bcdedd35a794175f71b067ba8504d686cce1d0c0f429b33c323c3c569ad4891e667574a49ff71d1b89a22cc66f13c65818c578"
}
